{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "project_brief",
  "type": "object",
  "required": [
    "project",
    "stage_status",
    "approved_by_user",
    "updated_at",
    "logline",
    "synopsis",
    "style",
    "duration_sec",
    "aspect_ratio",
    "scenes",
    "format_profile",
    "purpose",
    "visual_grammar"
  ],
  "properties": {
    "project": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "stage_status": {
      "enum": [
        "draft",
        "awaiting_approval",
        "approved"
      ]
    },
    "approved_by_user": {
      "type": "boolean"
    },
    "stale": {
      "type": "boolean",
      "default": false
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "logline": {
      "type": "string",
      "maxLength": 300
    },
    "synopsis": {
      "type": "string"
    },
    "style": {
      "type": "object",
      "required": [
        "visual"
      ],
      "properties": {
        "visual": {
          "type": "string",
          "description": "예: cinematic, anime, 3D render"
        },
        "tone": {
          "type": "string"
        },
        "avoid": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "duration_sec": {
      "type": "integer",
      "minimum": 1
    },
    "aspect_ratio": {
      "enum": [
        "16:9",
        "9:16",
        "1:1",
        "4:3",
        "21:9"
      ]
    },
    "target_audience": {
      "type": "string"
    },
    "budget_cap_credits": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "preferred_models": {
      "type": "object",
      "properties": {
        "image": {
          "type": [
            "string",
            "null"
          ]
        },
        "video": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "video_plan_notes": {
      "type": "string",
      "description": "Magnific video_plan 툴 결과 요약 (모델 추천, 클립 분할 계획)"
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "scene_id",
          "slugline",
          "summary",
          "value_shift"
        ],
        "properties": {
          "scene_id": {
            "type": "string",
            "pattern": "^s[0-9]{2,}$"
          },
          "slugline": {
            "type": "string",
            "description": "예: INT. COFFEE SHOP - NIGHT"
          },
          "summary": {
            "type": "string"
          },
          "characters": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "target_duration_sec": {
            "type": "integer"
          },
          "value_shift": {
            "type": "object",
            "required": [
              "from",
              "to",
              "mechanism"
            ],
            "description": "McKee 가치전환. from==to면 비사건 — 삭제/병합 검토 플래그.",
            "properties": {
              "from": {
                "enum": [
                  "+",
                  "-"
                ]
              },
              "to": {
                "enum": [
                  "+",
                  "-"
                ]
              },
              "mechanism": {
                "enum": [
                  "action",
                  "revelation"
                ]
              }
            }
          }
        }
      }
    },
    "format_profile": {
      "enum": [
        "cinematic_short",
        "commercial_30",
        "shorts_reels",
        "longform"
      ],
      "description": "포맷 프로파일(format-director 표). 구조 비트·ASL·훅·납품 규격을 결정한다. 포맷 규칙 > 영화 문법."
    },
    "purpose": {
      "enum": [
        "brand",
        "activation"
      ],
      "description": "영상 목적(Binet&Field 60/40). brand=감정·기억 연결 극대화, activation=오퍼·CTA 중심 — 크리에이티브 규칙 분기."
    },
    "visual_grammar": {
      "type": "object",
      "required": ["palette", "lighting_bible", "lens_bible", "camera_bible"],
      "description": "프로젝트 시각 문법 계약(스타일 바이블) — 실제 프로덕션의 룩북/쇼 바이블에 해당. 모델-프리(모델명 금지 — 모델 사실은 production_manifest.model_profile). 하류 전 스테이지가 이 블록을 verbatim 참조하며, 위반은 quality-reviewer grammar 축에서 심사된다. 어휘 정본: skills/filmcraft/references/.",
      "properties": {
        "design_concept": { "type": "string", "description": "월드를 통일하는 단일 메타포(예: '성당 같은 병원')" },
        "palette": {
          "type": "object",
          "required": ["dominant", "accent"],
          "properties": {
            "dominant": { "type": "string" },
            "subordinate": { "type": "string" },
            "accent": { "type": "string" },
            "harmony": { "enum": ["complementary", "split_complementary", "analogous", "triadic", "monochromatic_accent"] },
            "forbidden": { "type": "array", "items": { "type": "string" }, "description": "팔레트 오염 방지 — 긍정 재구성으로 프롬프트에 반영" }
          }
        },
        "color_script": {
          "type": "array",
          "description": "비트별 팔레트 아크(Pixar 컬러 스크립트 관행) — 드리프트 워크어라운드의 정본.",
          "items": {
            "type": "object",
            "required": ["beat", "palette_target"],
            "properties": {
              "beat": { "type": "string" },
              "palette_target": { "type": "string" },
              "saturation": { "enum": ["desaturated", "muted", "baseline", "saturated"] },
              "temperature": { "enum": ["warm", "neutral", "cool"] }
            }
          }
        },
        "location_palettes": { "type": "object", "additionalProperties": { "type": "string" }, "description": "장소별 컬러 시그니처 — 등장 시마다 verbatim 재주입" },
        "lighting_bible": {
          "type": "object",
          "required": ["default_ratio", "motivation_doctrine"],
          "properties": {
            "default_time_of_day": { "enum": ["dawn", "golden_hour", "day", "overcast", "blue_hour", "night", "interior_day", "interior_night"] },
            "default_key_quality": { "enum": ["hard", "soft"] },
            "default_ratio": { "enum": ["flat_1_1", "mild_2_1", "standard_4_1", "low_key_8_1", "extreme_16_1"] },
            "default_color_temp_k": { "type": "integer" },
            "motivation_doctrine": { "enum": ["motivated", "stylized"], "description": "motivated=모든 빛에 그럴듯한 출처(기본). stylized=비동기 조명 허용(선언적 선택)." }
          }
        },
        "lens_bible": {
          "type": "object",
          "required": ["default_mm_by_size"],
          "properties": {
            "format_note": { "type": "string", "default": "all mm full-frame equivalent" },
            "default_mm_by_size": {
              "type": "object",
              "description": "숏 사이즈 계열별 기본 초점거리(FF 환산). 예: {\"wide\":24,\"medium\":35,\"close\":85}",
              "additionalProperties": { "type": "integer" }
            },
            "aperture_default": { "type": "number" },
            "dof_default": { "enum": ["shallow", "medium", "deep"] }
          }
        },
        "look": {
          "type": "object",
          "properties": {
            "film_stock": { "enum": ["none", "kodak_portra_400", "kodak_vision3_500t", "cinestill_800t", "kodak_trix", "ilford_hp5", "super8", "arri_alexa"], "default": "none" },
            "lens_character": { "enum": ["spherical", "anamorphic", "vintage"], "default": "spherical" },
            "grain": { "enum": ["none", "fine_35mm", "coarse_16mm", "heavy_8mm"], "default": "none", "description": "게이지 텍스처만(색·리크·게이트위브가 포함된 super8 룩은 film_stock 소관)" },
            "diffusion": { "enum": ["none", "light", "medium", "heavy"], "default": "none" }
          }
        },
        "camera_bible": {
          "type": "object",
          "required": ["movement_rules"],
          "properties": {
            "default_support": { "enum": ["locked", "handheld", "stabilized", "drone"], "default": "locked" },
            "settle_required": { "type": "boolean", "default": true },
            "movement_rules": {
              "type": "object",
              "properties": {
                "max_moves_per_shot": { "type": "integer", "const": 1, "description": "1무브 법칙(저작 시 항상 1 — 병합은 produce 최적화)" },
                "banned_bases": { "type": "array", "items": { "type": "string" }, "description": "이 프로젝트에서 금지하는 무브(예: [\"whip_pan\",\"crash_zoom\"])" }
              }
            }
          }
        },
        "grade": {
          "type": "object",
          "properties": {
            "show_lut": { "type": ["string", "null"], "description": "시퀀스 공용 LUT 경로(.cube) — 렌더러가 lut3d로 균일 적용(구현됨). 씬별 eq 트림은 현재 수동 ffmpeg(로드맵) — 수행 시 edit_plan notes에 기록." },
            "correction_before_grade": { "type": "boolean", "default": true }
          }
        },
        "motion_bible": {
          "type": "object",
          "properties": {
            "easing_required": { "type": "boolean", "default": true },
            "moving_hold_required": { "type": "boolean", "default": true },
            "gesture_economy_max": { "type": "integer", "default": 2 },
            "shutter_look": { "enum": ["natural_180", "crisp_staccato"], "default": "natural_180" }
          }
        },
        "sound_bible": {
          "type": "object",
          "properties": {
            "diegesis_default": { "enum": ["score", "source"], "default": "score" },
            "lra_floor": { "type": ["number", "null"], "description": "다이내믹스 QA 하한(LU) — 미설정 시 프로파일 기본(잠정 4LU, cinematic/longform/brand만)" }
          }
        },
        "prohibitions": {
          "type": "object",
          "properties": {
            "greeking_required": { "type": "boolean", "default": false, "description": "상업물: 미승인 브랜드 마크 노출 금지(긍정 재구성 프롬프트 + QC 게이트)" },
            "flop_forbidden": { "type": "boolean", "default": true, "description": "좌우 반전 금지(텍스트·손방향·핸들 방향·참조뱅크 무효화)" },
            "baked_text_forbidden": { "type": "boolean", "default": true, "description": "생성 클립 내 텍스트 금지 — 전 텍스트는 후반 번인" }
          }
        }
      }
    },
    "brand_assets": {
      "type": "object",
      "description": "독특한 브랜드 자산 매니페스트(Byron Sharp DBA). 대화 기억이 아니라 여기에 기록 — 모든 스테이지가 참조.",
      "properties": {
        "logo_path": {
          "type": [
            "string",
            "null"
          ],
          "description": "로고 파일 경로 또는 creation identifier(배경 제거본 권장)"
        },
        "brand_colors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "hex 코드. 예 #FF6A00"
        },
        "slogan": {
          "type": [
            "string",
            "null"
          ]
        },
        "voice_rules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "보이스 규칙(경어체·표기 규칙 등)"
        },
        "banned_words": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "beat_map": {
      "type": "array",
      "description": "구조 비트의 백분율 배치 검증 기록(Save the Cat 축약 또는 훅-바디-CTA).",
      "items": {
        "type": "object",
        "required": [
          "beat",
          "at_pct"
        ],
        "properties": {
          "beat": {
            "enum": [
              "opening_image",
              "hook",
              "catalyst",
              "break_into_two",
              "midpoint",
              "all_is_lost",
              "break_into_three",
              "cta",
              "final_image"
            ]
          },
          "at_pct": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "scene_id": {
            "type": "string"
          }
        }
      }
    },
    "opening_image": {
      "type": [
        "string",
        "null"
      ],
      "description": "첫 컷 서술 — final_image와 변화 전/후 거울쌍"
    },
    "final_image": {
      "type": [
        "string",
        "null"
      ],
      "description": "끝 컷 서술 — opening_image의 거울상"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "purpose": {
            "const": "brand"
          }
        },
        "required": [
          "purpose"
        ]
      },
      "then": {
        "required": [
          "brand_assets"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "format_profile": {
            "enum": [
              "commercial_30",
              "shorts_reels"
            ]
          }
        },
        "required": [
          "format_profile"
        ]
      },
      "then": {
        "required": [
          "beat_map"
        ]
      }
    }
  ]
}