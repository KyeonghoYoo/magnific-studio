{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ykh6242/magnific-studio/schemas/edit_plan.schema.json",
  "title": "edit_plan",
  "description": "후반 편집(/ms-post)의 정본 아티팩트. 에이전트가 선언적 EDL(edit-as-data)로 컷/트랜지션/자막/음악/납품본을 기술하고, 결정적 ffmpeg 실행기가 이를 렌더한다. ShortGPT의 편집 마크업 패턴 차용.",
  "type": "object",
  "required": ["project", "stage_status", "approved_by_user", "stale", "updated_at", "timeline", "audio", "deliverables"],
  "properties": {
    "project": { "type": "string", "description": "프로젝트 슬러그" },
    "stage_status": { "enum": ["draft", "awaiting_approval", "approved"] },
    "approved_by_user": { "type": "boolean" },
    "stale": { "type": "boolean" },
    "updated_at": { "type": "string", "description": "ISO8601" },
    "schema_version": { "type": "string", "default": "1.0", "description": "edit_plan EDL 스키마 버전. 재렌더·마이그레이션 호환성 판단용." },
    "pipeline_version": { "type": "string", "description": "이 계획을 렌더한 post-production 레시피/플러그인 버전(예: magnific-studio 0.6.0). 결정적 재현의 바인딩." },
    "render": {
      "type": "object",
      "description": "결정적 렌더 파라미터. 여기에 명시된 값만으로 소스에서 동일 산출물을 재현한다(암묵값 금지 = 멱등성).",
      "properties": {
        "fps": { "type": "integer", "default": 30 },
        "width": { "type": "integer" },
        "height": { "type": "integer" },
        "video_codec": { "type": "string", "default": "libx264" },
        "crf": { "type": "integer", "default": 19 },
        "preset": { "type": "string", "default": "veryfast" },
        "pix_fmt": { "type": "string", "default": "yuv420p" },
        "container": { "type": "string", "default": "mp4" },
        "faststart": { "type": "boolean", "default": true },
        "audio_codec": { "type": "string", "default": "aac" },
        "audio_bitrate": { "type": "string", "default": "192k" },
        "sample_rate": { "type": "integer", "default": 44100 },
        "deterministic": { "type": "boolean", "default": true, "description": "동일 edit_plan + 동일 소스 → 프레임 결정적 재렌더(컨테이너 타임스탬프 제외 프레임 동일). 인코더 파라미터 고정 필수." }
      }
    },
    "source": {
      "type": "object",
      "description": "편집 소재의 출처 + 지문. 재렌더 전 지문을 대조해 소스 변경(=stale)을 탐지한다.",
      "properties": {
        "master_aspect": { "type": "string", "description": "예 16:9 또는 9:16 (네이티브 소재 비율)" },
        "fps": { "type": "number" },
        "renders_dir": { "type": "string", "description": "다운로드한 클립 mp4들이 있는 로컬 경로" },
        "clips": {
          "type": "array",
          "description": "소스 클립 지문(멱등성 가드). 재렌더 시 duration/size(또는 sha256)가 바뀌었으면 소스가 달라진 것 — 경고.",
          "items": {
            "type": "object",
            "required": ["clip_id"],
            "properties": {
              "clip_id": { "type": "string" },
              "file": { "type": "string" },
              "duration": { "type": "number" },
              "size_bytes": { "type": "integer" },
              "sha256": { "type": "string", "description": "선택 — 강한 지문." }
            }
          }
        }
      }
    },
    "timeline": {
      "type": "array",
      "description": "재생 순서의 컷 리스트. 균일한 생성 클립 길이를 감정 비트에 맞춰 트림·완급 조정한다.",
      "items": {
        "type": "object",
        "required": ["clip_id", "in", "out"],
        "properties": {
          "clip_id": { "type": "string", "description": "production_manifest의 shot clip creation_identifier 또는 로컬 파일명" },
          "shot_id": { "type": "string", "description": "storyboard 숏 id (추적용)" },
          "in": { "type": "number", "description": "소스 인점(초)" },
          "out": { "type": "number", "description": "소스 아웃점(초)" },
          "speed": { "type": "number", "default": 1.0, "description": "속도 배율(선택)" },
          "transition_in": {
            "type": "object",
            "description": "앞 컷과의 전환. 첫 컷은 생략/none.",
            "properties": {
              "type": { "enum": ["cut", "fade", "dissolve", "fadeblack", "fadewhite", "wipeleft", "wiperight", "slideup", "slidedown", "circleopen", "radial"], "description": "매끈한 전환은 fade(크로스디졸브) 우선. ffmpeg dissolve는 노이즈 디더라 AI 생성 클립에서 지지직거림 — 그레인 의도 아니면 피한다." },
              "duration": { "type": "number", "description": "전환 길이(초). xfade duration." }
            }
          },
          "freeze_tail": { "type": "number", "description": "컷 마지막 N초를 정지 프레임으로 프리즈(초). UI 화면 픽셀정확 CTA 마감 등. 0이면 없음." },
          "notes": { "type": "string" }
        }
      }
    },
    "captions": {
      "type": "array",
      "description": "번인 자막/카피. 브랜드 보이스 준수. 단일 라벨은 static, 워드 카라오케는 word_timings 사용.",
      "items": {
        "type": "object",
        "required": ["text", "start", "end"],
        "properties": {
          "text": { "type": "string" },
          "start": { "type": "number", "description": "타임라인 기준 시작(초)" },
          "end": { "type": "number", "description": "타임라인 기준 끝(초)" },
          "style": { "type": "string", "description": "captions.styles의 스타일 키", "default": "body" },
          "word_timings": {
            "type": "array",
            "description": "카라오케(\\k)용 워드 타이밍. WhisperX 강제정렬 또는 수동. Remotion Caption 스키마 호환.",
            "items": {
              "type": "object",
              "required": ["word", "start_ms", "end_ms"],
              "properties": {
                "word": { "type": "string" },
                "start_ms": { "type": "integer" },
                "end_ms": { "type": "integer" }
              }
            }
          }
        }
      }
    },
    "caption_style": {
      "type": "object",
      "description": "번인 자막 렌더 규약.",
      "properties": {
        "font": { "type": "string", "default": "Pretendard", "description": "한글은 Pretendard 또는 Noto Sans CJK KR. 폰트 경로/디렉토리 명시." },
        "fontfile": { "type": "string" },
        "engine": { "enum": ["ass", "drawtext"], "default": "ass", "description": "스타일/카라오케는 ass(libass), 단일 정적 라벨만 drawtext" },
        "margin_v": { "type": "integer", "default": 360, "description": "1080x1920 기준 하단 세이프. UI 오버레이 회피." }
      }
    },
    "audio": {
      "type": "object",
      "required": ["music"],
      "properties": {
        "music": {
          "type": "object",
          "properties": {
            "source": { "type": "string", "description": "로컬 경로 또는 creation identifier" },
            "sync_offset": { "type": "number", "description": "음악 시작을 타임라인 어디에 정렬할지(초). 음(-)이면 음악을 앞당김." },
            "build_target": { "type": "number", "description": "음악 빌드/드롭이 정렬돼야 하는 타임라인 지점(초) — 서사 전환점(예: 라이딩 시작)." },
            "gain_db": { "type": "number", "default": 0 },
            "fade_in": { "type": "number", "default": 0 },
            "fade_out": { "type": "number", "default": 1.5 }
          }
        },
        "clip_audio": { "type": "string", "enum": ["strip", "keep", "sfx_only"], "default": "strip", "description": "생성 클립 자체 오디오 처리. 기본 제거(앰비언스 불일치 방지)." },
        "voiceover": {
          "type": "object",
          "description": "내레이션 VO(선택). 있으면 음악에 sidechain 덕킹 적용하고, 워드 타이밍으로 카라오케 자막을 자동 생성할 수 있다.",
          "properties": {
            "source": { "type": "string", "description": "로컬 VO 경로 또는 creation identifier. generate=true면 audio_tts 결과가 채워진다." },
            "script": { "type": "string", "description": "TTS 대본(generate=true일 때). 브랜드 보이스 준수." },
            "generate": { "type": "boolean", "default": false, "description": "true면 audio_tts로 생성(견적 게이트). false면 source 사용." },
            "voice": { "type": "string", "description": "audio_voices_list에서 선택한 보이스 id/이름." },
            "gain_db": { "type": "number", "default": 0 },
            "auto_captions": { "type": "boolean", "default": false, "description": "true면 WhisperX/faster-whisper로 VO 워드 타이밍을 뽑아 captions[].word_timings(카라오케)를 채운다." }
          }
        },
        "ducking": {
          "type": "object",
          "description": "VO가 있을 때 음악 사이드체인 덕킹 파라미터.",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "threshold": { "type": "number", "default": 0.03 },
            "ratio": { "type": "number", "default": 8 },
            "attack_ms": { "type": "number", "default": 20 },
            "release_ms": { "type": "number", "default": 300 }
          }
        },
        "loudness_lufs": { "type": "number", "default": -14, "description": "최종 통합 라우드니스 타깃" },
        "true_peak_db": { "type": "number", "default": -1.5 }
      }
    },
    "deliverables": {
      "type": "array",
      "description": "납품본 매트릭스. 마스터 1개 + 파생본(플랫폼/컷다운).",
      "items": {
        "type": "object",
        "required": ["name", "aspect", "width", "height"],
        "properties": {
          "name": { "type": "string", "description": "출력 파일명(확장자 포함)" },
          "aspect": { "type": "string", "description": "예 9:16, 16:9, 1:1" },
          "width": { "type": "integer" },
          "height": { "type": "integer" },
          "reframe": { "enum": ["native", "blur_pad", "pad", "center_crop", "auto_reframe"], "default": "native", "description": "다른 비율 파생 시 재구성 방식. native=재구도 소재 사용(최선)." },
          "max_duration": { "type": "number", "description": "플랫폼 상한(초). Shorts 180 등." },
          "target": { "type": "string", "description": "예 instagram_reels | youtube_shorts | tiktok | master" },
          "path": { "type": "string", "description": "완료 후 저장 경로" },
          "magnific_creation": { "type": "string", "description": "Space 아카이브용 업로드 creation identifier(Step 6)" },
          "space_node": { "type": "string", "description": "Space 캔버스의 최종본 노드 id(Step 6)" }
        }
      }
    },
    "variants": {
      "type": "array",
      "description": "A/B 변형. 같은 소스 클립을 공유하며 base 대비 오버라이드만 기술한다 — 생성 재소비 0으로 다변형 렌더. diff·비교가 쉽다.",
      "items": {
        "type": "object",
        "required": ["name", "overrides"],
        "properties": {
          "name": { "type": "string", "description": "변형 식별자(예: capA_hookB)" },
          "overrides": {
            "type": "object",
            "description": "base edit_plan에 얹는 부분 패치. 지정한 키만 교체된다.",
            "properties": {
              "captions": { "type": "array", "description": "자막 전체 교체(카피 A/B 테스트)." },
              "audio": { "type": "object", "description": "음악/싱크 오버라이드." },
              "timeline_trims": { "type": "array", "description": "일부 컷 in/out·전환 오버라이드.", "items": { "type": "object" } },
              "render": { "type": "object", "description": "렌더 파라미터 오버라이드(해상도·길이 등)." }
            }
          },
          "deliverable_suffix": { "type": "string", "description": "출력 파일명 접미사(예: _capB)." },
          "path": { "type": "string" },
          "magnific_creation": { "type": "string" }
        }
      }
    },
    "qc": {
      "type": "object",
      "description": "납품 전 자동 검수 결과(ffprobe + 프레임 추출 = quality-reviewer 최종 렌더 심사). 실패 시 납품 금지.",
      "properties": {
        "passed": { "type": "boolean" },
        "checks": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
