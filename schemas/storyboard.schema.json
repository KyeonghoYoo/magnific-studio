{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "storyboard",
  "type": "object",
  "required": ["project", "stage_status", "approved_by_user", "updated_at", "shots"],
  "properties": {
    "project": { "type": "string" },
    "stage_status": { "enum": ["draft", "awaiting_approval", "approved"] },
    "approved_by_user": { "type": "boolean" },
    "stale": { "type": "boolean", "default": false },
    "updated_at": { "type": "string", "format": "date-time" },
    "shots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["shot_id", "scene_id", "camera", "variation_type", "characters", "first_frame_desc", "motion_desc", "duration_sec"],
        "properties": {
          "shot_id": { "type": "string", "pattern": "^s[0-9]{2,}_sh[0-9]{2,}$" },
          "scene_id": { "type": "string" },
          "camera": {
            "type": "object",
            "required": ["shot_size", "angle", "movement", "position_id"],
            "properties": {
              "shot_size": { "enum": ["extreme_wide", "wide", "full", "medium", "medium_close_up", "close_up", "extreme_close_up"] },
              "angle": { "enum": ["eye_level", "high", "low", "overhead", "dutch"] },
              "movement": { "enum": ["static", "pan_left", "pan_right", "tilt_up", "tilt_down", "dolly_in", "dolly_out", "slow_push_in", "pull_back", "handheld", "orbit", "crane"] },
              "lens": { "type": "string", "description": "예: 24mm, 50mm, 85mm" },
              "position_id": { "type": "string", "description": "물리적 카메라 포지션 그룹 키. 예: cam01" }
            }
          },
          "variation_type": {
            "enum": ["small", "medium", "large"],
            "description": "small=첫프레임만+FF2V, medium/large=첫+끝프레임+FLF2V"
          },
          "characters": { "type": "array", "items": { "type": "string" }, "description": "characters.json의 key 참조" },
          "first_frame_desc": { "type": "string", "description": "정적 스냅샷. 진행형 동작 금지" },
          "last_frame_desc": { "type": ["string", "null"], "description": "variation_type=small이면 null" },
          "motion_desc": { "type": "string", "description": "카메라 무브먼트 + 인물 동작. 캐릭터는 appearance_phrase로 지칭" },
          "dialogue": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["speaker", "line"],
              "properties": {
                "speaker": { "type": "string" },
                "emotion": { "type": "string" },
                "line": { "type": "string" }
              }
            }
          },
          "sound": { "type": "array", "items": { "type": "string" } },
          "duration_sec": { "type": "number", "minimum": 1, "maximum": 15 }
        },
        "allOf": [
          {
            "if": { "properties": { "variation_type": { "const": "small" } } },
            "then": { "properties": { "last_frame_desc": { "type": "null" } } },
            "else": { "required": ["last_frame_desc"], "properties": { "last_frame_desc": { "type": "string" } } }
          }
        ]
      }
    }
  }
}
